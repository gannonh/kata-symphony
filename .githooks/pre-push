#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

echo "[pre-push] running local CI gate with evidence checks..."
source "${ROOT_DIR}/scripts/harness/common.sh"
if [[ -z "${HARNESS_BASE_REF:-}" ]]; then
  HARNESS_BASE_REF="$(harness_resolve_base_ref)"
fi
export HARNESS_BASE_REF
env -i \
  PATH="${PATH}" \
  HOME="${HOME}" \
  SHELL="${SHELL:-/bin/bash}" \
  TERM="${TERM:-}" \
  TMPDIR="${TMPDIR:-/tmp}" \
  HARNESS_BASE_REF="${HARNESS_BASE_REF}" \
  HARNESS_EVIDENCE_PATH="${HARNESS_EVIDENCE_PATH:-}" \
  pnpm run ci:local
