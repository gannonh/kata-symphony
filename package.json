{
  "name": "kata-symphony",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Symphony orchestration service scaffold",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
