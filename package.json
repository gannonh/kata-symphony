{
  "name": "kata-symphony",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Symphony orchestration service scaffold",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run tests/domain tests/contracts tests/scaffold",
    "test:integration": "vitest run tests/bootstrap",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "ci:local": "bash scripts/ci-local.sh",
    "hooks:install": "bash scripts/install-githooks.sh",
    "start": "tsx src/main.ts",
    "dev": "tsx watch src/main.ts"
  },
  "dependencies": {
    "liquidjs": "^10.19.1",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/node": "^22.13.10",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.22.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1",
    "vitest": "^3.0.8"
  },
  "packageManager": "pnpm@10.6.5"
}
